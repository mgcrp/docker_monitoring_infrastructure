# Copy this file to .env and adjust values as needed

# Ports exposed on the host
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
CADVISOR_PORT=8080
NODE_EXPORTER_PORT=9100

# Grafana admin credentials (password is required, no insecure default)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# cadvisor-proxy basic auth credentials (cAdvisor itself has no auth of its
# own, so it's only reachable through this authenticated proxy)
CADVISOR_AUTH_USER=
CADVISOR_AUTH_PASSWORD=
