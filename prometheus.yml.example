# Copy this file to prometheus.yml and adjust the target lists below.
# prometheus.yml is loaded read-only into the prometheus container (see docker-compose.yml).

global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  # Prometheus scraping itself
  - job_name: "prometheus"
    static_configs:
      - targets: ["localhost:9090"]

  # cAdvisor - container metrics
  # cAdvisor has no authentication of its own, so it's only reachable
  # through the cadvisor-proxy service (nginx + basic auth). Credentials
  # below must match CADVISOR_AUTH_USER/CADVISOR_AUTH_PASSWORD in .env.
  # Remote hosts must run their own cadvisor + cadvisor-proxy pair.
  - job_name: "cadvisor"
    basic_auth:
      username: "myuser"
      password: "mypassword"
    static_configs:
      # local host
      - targets: ["cadvisor-proxy:80"]
        labels:
          host: "localhost"
      # remote hosts - add one line per host running cadvisor-proxy
      - targets:
          - "192.168.1.10:8080"
          - "192.168.1.11:8080"
        labels:
          host: "remote"

  # node-exporter - host metrics
  - job_name: "node-exporter"
    static_configs:
      # local host
      - targets: ["node-exporter:9100"]
        labels:
          host: "localhost"
      # remote hosts - add one line per host running node-exporter
      - targets:
          - "192.168.1.10:9100"
          - "192.168.1.11:9100"
        labels:
          host: "remote"
